---
import Base from "../../layouts/Base.astro";
import { Image, getImage } from "astro:assets";
import { films } from "../../data/films.ts";

export async function getStaticPaths() {
  return films.map((f) => ({ params: { slug: f.slug }, props: { film: f } }));
}

const { film } = Astro.props;
const idx = films.findIndex((f) => f.slug === film.slug);
const next = films[(idx + 1) % films.length];
const creditsLine = [film.kind, film.year, film.director && `dir. ${film.director}`]
  .filter(Boolean)
  .join(" · ");

// Lightbox needs plain URLs; serve a large WebP variant rather than the
// multi-MB original.
const lbUrls = film.stills
  ? await Promise.all(
      film.stills.map(async (s) => (await getImage({ src: s, width: 1600, format: "webp" })).src),
    )
  : [];
---

<Base title={`${film.title} - Ross Imlach`} description={film.synopsis ?? `${film.title} (${film.year}) - cinematography by Ross Imlach.`}>
  <nav class="nav">
    <div class="nav-wordmark">
      <a href="/" class="name">Ross Imlach</a>
      <span class="crumb">
        <a href="/cinematography">Cinematography</a>
        <span class="sep">/</span>
        <span class="here">{film.title}</span>
      </span>
    </div>
    <div class="nav-links">
      <a href="/cinematography">← All work</a>
      <a href="mailto:dp@imla.ch">dp@imla.ch</a>
    </div>
  </nav>

  <main class="stage">
    <header class="pf-head">
      <h1>{film.title}</h1>
      <p class="credits-line">{creditsLine}</p>
      {film.synopsis && <p class="synopsis">{film.synopsis}</p>}
    </header>

    <div class="hero">
      <Image src={film.hero} alt={film.title} widths={[800, 1440, 1920]} sizes="100vw" />
    </div>

    {
      film.stills && film.stills.length > 0 ? (
        <section class="stills">
          {film.stills.map((s, i) => (
            <button class="still" data-index={i} aria-label="Open still">
              <Image src={s} alt="" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
            </button>
          ))}
        </section>
      ) : (
        <p class="pending">Full case study in progress - get in touch for the reel and stills.</p>
      )
    }

    <div class="rosters">
      {
        film.credits && (
          <section class="roster">
            <h2>Credits</h2>
            {film.credits.map((c) => (
              <div class="row"><span class="role">{c.role}</span><span class="name-v">{c.name}</span></div>
            ))}
          </section>
        )
      }
      {
        film.tech && (
          <section class="roster">
            <h2>Tech</h2>
            {film.tech.map((t) => (
              <div class="row"><span class="role">{t.label}</span><span class="name-v">{t.value}</span></div>
            ))}
          </section>
        )
      }
    </div>

    <a class="next" href={`/portfolio/${next.slug}`}>
      <Image src={next.hero} alt="" widths={[800, 1600]} sizes="100vw" class="next-bg" />
      <div class="next-gradient"></div>
      <div class="next-body">
        <span class="next-label">Next case study -</span>
        <div class="next-row">
          <span class="next-title">{next.title}</span>
          <span class="next-open"><span>Open</span><span class="arrow">→</span></span>
        </div>
      </div>
    </a>

    <footer class="folio">
      <span>imla.ch / cinematography / {film.title}</span>
      <span><a href="/cinematography">← All work</a></span>
    </footer>
  </main>

  {
    film.stills && film.stills.length > 0 && (
      <div class="lightbox" id="lightbox" hidden>
        <button class="lb-close" aria-label="Close">✕</button>
        <button class="lb-prev" aria-label="Previous">←</button>
        <img id="lb-img" src="" alt="" />
        <button class="lb-next" aria-label="Next">→</button>
      </div>
      <script is:inline define:vars={{ stills: lbUrls }}>
        const box = document.getElementById("lightbox");
        const img = document.getElementById("lb-img");
        let cur = 0;
        const show = (i) => {
          cur = (i + stills.length) % stills.length;
          img.src = stills[cur];
          box.hidden = false;
        };
        document.querySelectorAll(".still").forEach((b) =>
          b.addEventListener("click", () => show(Number(b.dataset.index))),
        );
        box.querySelector(".lb-close").addEventListener("click", () => (box.hidden = true));
        box.querySelector(".lb-prev").addEventListener("click", (e) => { e.stopPropagation(); show(cur - 1); });
        box.querySelector(".lb-next").addEventListener("click", (e) => { e.stopPropagation(); show(cur + 1); });
        box.addEventListener("click", (e) => { if (e.target === box || e.target === img) box.hidden = true; });
        document.addEventListener("keydown", (e) => {
          if (box.hidden) return;
          if (e.key === "Escape") box.hidden = true;
          if (e.key === "ArrowLeft") show(cur - 1);
          if (e.key === "ArrowRight") show(cur + 1);
        });
      </script>
    )
  }
</Base>

<style>
  .pf-head { max-width: 920px; padding-bottom: 36px; }
  .pf-head h1 {
    font-weight: 600; font-size: clamp(48px, 7vw, 120px);
    line-height: 0.9; letter-spacing: -0.04em; margin: 0 0 20px;
  }
  .pf-head .credits-line { font-size: 15px; color: var(--ink-faint); margin: 0 0 18px; letter-spacing: 0.02em; }
  .pf-head .synopsis { font-size: 20px; line-height: 1.5; color: var(--ink-dim); max-width: 60ch; margin: 0; text-wrap: balance; }

  .hero { margin: 8px 0 12px; border: 1px solid var(--rule); overflow: hidden; }
  .hero img { display: block; width: 100%; height: auto; }

  .stills { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin: 12px 0; }
  .still { padding: 0; border: 1px solid var(--rule); background: var(--bg-2); cursor: zoom-in; overflow: hidden; }
  .still img { display: block; width: 100%; height: auto; transition: transform 0.6s cubic-bezier(0.2,0.8,0.2,1); }
  .still:hover img { transform: scale(1.03); }

  .pending { font-size: 16px; color: var(--ink-dim); margin: 28px 0; }

  .rosters { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; margin: 56px 0; }
  .roster h2 { font-weight: 500; font-size: 14px; letter-spacing: 0.04em; color: var(--ink-faint); margin: 0 0 16px; text-transform: uppercase; }
  .roster .row { display: flex; justify-content: space-between; gap: 24px; padding: 12px 0; border-top: 1px solid var(--rule); font-size: 15px; }
  .roster .role { color: var(--ink-dim); }
  .roster .name-v { color: var(--ink); text-align: right; }

  .next {
    position: relative; display: block;
    height: 380px; overflow: hidden;
    margin-top: 24px;
    border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);
  }
  .next .next-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.8);
    transition: filter 0.4s, transform 6s cubic-bezier(0.4, 0, 0.6, 1);
  }
  .next:hover .next-bg {
    filter: brightness(0.9);
    transform: scale(1.03);
  }
  .next .next-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.25) 60%, transparent 100%);
  }
  .next .next-body {
    position: absolute; left: 36px; right: 36px; bottom: 32px;
  }
  .next .next-label {
    display: block; font-size: 13px; color: var(--ink-faint);
    letter-spacing: 0.04em; margin-bottom: 14px;
  }
  .next .next-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
  }
  .next .next-title {
    font-size: clamp(36px, 5vw, 64px); font-weight: 500; letter-spacing: -0.03em;
    line-height: 1.0; color: var(--ink);
  }
  .next .next-open {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px; color: var(--ink);
    border-bottom: 1px solid var(--rule); padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .next .next-open .arrow { transition: transform 0.25s; }
  .next:hover .next-open { color: var(--accent); border-color: var(--accent); }
  .next:hover .next-open .arrow { transform: translateX(4px); }

  .lightbox {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(6,6,7,0.94);
    display: flex; align-items: center; justify-content: center;
  }
  .lightbox[hidden] { display: none; }
  .lightbox #lb-img { max-width: 92vw; max-height: 88vh; object-fit: contain; }
  .lightbox button {
    position: absolute; background: transparent; border: 1px solid var(--rule);
    color: var(--ink); width: 44px; height: 44px; cursor: pointer; font-size: 16px;
  }
  .lb-close { top: 24px; right: 24px; }
  .lb-prev { left: 24px; top: 50%; transform: translateY(-50%); }
  .lb-next { right: 24px; top: 50%; transform: translateY(-50%); }

  @media (max-width: 900px) {
    .stills, .rosters { grid-template-columns: 1fr; }
  }
</style>

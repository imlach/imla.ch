---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("engineering", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
---

<Base title={`${post.data.title} — Ross Imlach`} description={post.data.summary} palette="cream">
  <nav class="nav">
    <div class="nav-wordmark">
      <a href="/" class="name">Ross Imlach</a>
      <span class="crumb">
        <a href="/engineering">Engineering</a>
        <span class="sep">/</span>
        <span class="here">Reading</span>
      </span>
    </div>
    <div class="nav-links">
      <a href="/engineering">← Back to index</a>
      <a href="mailto:eng@imla.ch">eng@imla.ch</a>
    </div>
  </nav>

  <main class="stage">
    <header class="post-header">
      <div class="post-meta">
        <span>{fmt(post.data.date)}</span>
        <span class="dot">·</span>
        <span>{post.data.readingTime} read</span>
      </div>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.summary}</p>
    </header>

    <article class="eng-prose">
      <Content />
    </article>

    <footer class="folio">
      <span><a href="/engineering">← Back to the index</a></span>
      <span>Write — <a href="mailto:eng@imla.ch">eng@imla.ch</a> · <a href="/about">About</a></span>
    </footer>
  </main>
</Base>

<style>
  .post-header { max-width: 760px; padding-bottom: 40px; border-bottom: 1px solid var(--rule); }
  .post-meta { display: flex; gap: 12px; align-items: baseline; font-size: 13px; color: var(--ink-faint); margin-bottom: 24px; }
  .post-header h1 { font-weight: 700; font-size: clamp(36px, 5vw, 60px); line-height: 1.02; letter-spacing: -0.03em; margin: 0 0 24px; }
  .post-header .lede { font-size: 20px; line-height: 1.5; color: var(--ink-dim); margin: 0; max-width: 60ch; text-wrap: balance; }
  .folio { margin-top: 80px; }
</style>

<!-- MDX-rendered content is global; scope it under .eng-prose. -->
<style is:global>
  .eng-prose { max-width: 680px; margin-top: 44px; font-size: 18px; line-height: 1.7; color: var(--ink-dim); }
  .eng-prose > * { margin: 0 0 24px; }
  .eng-prose h2 { font-weight: 600; font-size: 28px; line-height: 1.2; letter-spacing: -0.02em; color: var(--ink); margin: 48px 0 16px; }
  .eng-prose h3 { font-weight: 600; font-size: 21px; color: var(--ink); margin: 36px 0 12px; }
  .eng-prose strong { color: var(--ink); font-weight: 600; }
  .eng-prose a { color: var(--ink); border-bottom: 1px solid var(--rule); }
  .eng-prose a:hover { border-color: var(--accent); color: var(--accent); }
  .eng-prose ol, .eng-prose ul { padding-left: 1.3em; }
  .eng-prose li { margin: 0 0 8px; }
  .eng-prose blockquote {
    margin: 32px 0; padding: 4px 0 4px 24px;
    border-left: 2px solid var(--accent);
    color: var(--ink); font-style: italic;
  }
  .eng-prose pre {
    background: var(--bg-2); border: 1px solid var(--rule);
    padding: 20px 22px; overflow-x: auto; font-size: 14px; line-height: 1.55;
    font-family: ui-monospace, "JetBrains Mono", SFMono-Regular, Menlo, monospace;
  }
  .eng-prose code { font-family: ui-monospace, "JetBrains Mono", SFMono-Regular, Menlo, monospace; font-size: 0.92em; }
  .eng-prose :not(pre) > code { background: var(--bg-2); padding: 1px 5px; border: 1px solid var(--rule); }
</style>
